@page
@using System.Globalization
@model EventsModel
@{
    ViewData["Title"] = "Events";
}

<section class="panel">
    <h1>Webhook events</h1>
    <table>
        <thead>
            <tr>
                <th>Received</th>
                <th>Event</th>
                <th>Reason</th>
                <th>Session</th>
                <th>Status</th>
                <th>Deliveries</th>
                <th>Last error</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var webhookEvent in Model.Events)
            {
                var receivedAtUtc = webhookEvent.ReceivedAtUtc.ToUniversalTime();
                var receivedAtIsoTimestamp = receivedAtUtc.ToString("yyyy-MM-dd'T'HH:mm:ss'Z'", CultureInfo.InvariantCulture);
                var receivedAtFallbackText = receivedAtUtc.ToString("yyyy-MM-dd HH:mm:ss 'UTC'", CultureInfo.InvariantCulture);
                <tr>
                    <td>
                        <time datetime="@receivedAtIsoTimestamp" data-device-time="true">@receivedAtFallbackText</time>
                    </td>
                    <td>@webhookEvent.EventType</td>
                    <td>
                        @webhookEvent.Reason
                        @if (webhookEvent.SoftLockedSessionCount is not null)
                        {
                            <span class="muted">(@webhookEvent.SoftLockedSessionCount)</span>
                        }
                    </td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(webhookEvent.SessionIdentifier))
                        {
                            <span>@(string.IsNullOrWhiteSpace(webhookEvent.ProviderName) ? webhookEvent.Provider : $"{webhookEvent.Provider}:{webhookEvent.ProviderName}")</span>
                            <span class="muted"> @webhookEvent.SessionIdentifier</span>
                            @if (!string.IsNullOrWhiteSpace(webhookEvent.EndReason))
                            {
                                <span class="muted"> @webhookEvent.EndReason</span>
                            }
                            @if (webhookEvent.ActiveSessionCount is not null)
                            {
                                <span class="muted"> active=@webhookEvent.ActiveSessionCount</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(webhookEvent.WorkingDirectory))
                            {
                                <span class="muted"> cwd=@webhookEvent.WorkingDirectory</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(webhookEvent.TranscriptPath))
                            {
                                <span class="muted"> transcript=@webhookEvent.TranscriptPath</span>
                            }
                        }
                        else
                        {
                            <span class="muted">-</span>
                        }
                    </td>
                    <td>@webhookEvent.Status</td>
                    <td>
                        @webhookEvent.SuccessCount success /
                        @webhookEvent.PermanentFailureCount permanent /
                        @webhookEvent.TransientFailureCount transient
                    </td>
                    <td>@(webhookEvent.LastError ?? "-")</td>
                </tr>
            }
        </tbody>
    </table>
    @if (Model.Events.Count == 0)
    {
        <p class="muted">No events recorded.</p>
    }
</section>

<script src="~/local-time.js" asp-append-version="true"></script>
